# Environment Variables
# Set this file to .env and DO NOT commit .env to version control

# Database Configuration
# Turso (Production)
# Get database URL: turso db show cashflow --url
# Get auth token: turso db tokens create cashflow
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your_auth_token_here

# Or use local SQLite for development (default behavior)
# Leave both empty for local development with ./cashflow.db

# Server Configuration
PORT=10000

# CORS Configuration
# Set to your frontend URL (default: http://localhost:5173)
FRONTEND_URL=https://your-frontend.onrender.com
